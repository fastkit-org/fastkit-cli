from fastapi import APIRouter, Depends, status
from sqlalchemy.orm import Session
from pydantic import ValidationError
from starlette.responses import JSONResponse

from fastkit_core.database import get_db
from fastkit_core.http import success_response, error_response, paginated_response
from fastkit_core.validation.errors import format_validation_errors
from fastkit_core.i18n import _
from .service import {{ model_name }}Service
from .schemas import {{ model_name }}Create, {{ model_name }}Update, {{ model_name }}Response

router = APIRouter(
    prefix="/{{ table_name }}",
    tags=["{{ model_name }}"],
)


def get_service(session: Session = Depends(get_db)) -> {{ model_name }}Service:
    return {{ model_name }}Service(session)


@router.get("/", response_model=list[{{ model_name }}Response])
def index(
    page: int = 1,
    per_page: int = 20,
    service: {{ model_name }}Service = Depends(get_service),
) -> JSONResponse:
    items, meta = service.paginate(page=page, per_page=per_page)
    return paginated_response(items=items, pagination=meta)


@router.get("/{id}", response_model={{ model_name }}Response)
def show(
    id: int,
    service: {{ model_name }}Service = Depends(get_service),
) -> JSONResponse:
    item = service.find_or_fail(id)
    return success_response(data=item.model_dump())


@router.post("/", response_model={{ model_name }}Response, status_code=status.HTTP_201_CREATED)
def store(
    data: {{ model_name }}Create,
    service: {{ model_name }}Service = Depends(get_service),
) -> JSONResponse:
    try:
        item = service.create(data)
        return success_response(data=item.model_dump(), status_code=status.HTTP_201_CREATED)
    except ValidationError as e:
        errors = format_validation_errors(e.errors())
        return error_response(message=_('validation.failed'), errors=errors, status_code=422)


@router.put("/{id}", response_model={{ model_name }}Response)
def update(
    id: int,
    data: {{ model_name }}Update,
    service: {{ model_name }}Service = Depends(get_service),
) -> JSONResponse:
    try:
        item = service.update(id, data)
        return success_response(data=item.model_dump())
    except ValidationError as e:
        errors = format_validation_errors(e.errors())
        return error_response(message=_('validation.failed'), errors=errors, status_code=422)


@router.delete("/{id}", status_code=status.HTTP_204_NO_CONTENT)
def destroy(
    id: int,
    service: {{ model_name }}Service = Depends(get_service),
) -> None:
    service.delete(id)
